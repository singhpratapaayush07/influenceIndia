generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String?   // Nullable: set after OTP verification or null for OAuth users
  userType           String    // "brand" | "influencer" | "admin"
  emailVerified      Boolean   @default(false)
  authProvider       String?   // "google" | null (for email/password)
  onboardingComplete Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  influencerProfile  InfluencerProfile?
  brandProfile       BrandProfile?
  sentRequests       ContactRequest[]   @relation("BrandRequests")
  receivedRequests   ContactRequest[]   @relation("InfluencerRequests")
  sentMessages       Message[]          @relation("SentMessages")
  receivedMessages   Message[]          @relation("ReceivedMessages")

  @@map("users")
}

model InfluencerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  displayName       String
  bio               String?
  niches            Json     @default("[]")
  instagramHandle   String?
  youtubeHandle     String?
  tiktokHandle      String?
  followerCount     Int      @default(0)
  engagementRate    Float    @default(0)
  viralityScore     Float    @default(0)
  overallScore      Float    @default(0)
  isVerified        Boolean  @default(false)
  isFeatured        Boolean  @default(false)
  profilePictureUrl String?
  city              String?
  languages         Json     @default("[]")
  gender            String?
  ageRange          String?
  primaryLanguage   String?
  responseRate      Float?   @default(0)
  avgResponseTime   Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  pricing   InfluencerPricing[]
  requests  ContactRequest[]    @relation("InfluencerProfileRequests")
  proposals CampaignProposal[]
  favorites Favorite[]

  @@map("influencer_profiles")
}

model InfluencerPricing {
  id             String   @id @default(cuid())
  influencerId   String
  tierType       String   // "story" | "post" | "reel" | "video"
  priceInr       Int
  description    String?
  deliverables   String?
  turnaroundDays Int      @default(7)
  createdAt      DateTime @default(now())

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@map("influencer_pricing")
}

model BrandProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String
  industry     String?
  website      String?
  logoUrl      String?
  description  String?
  budgetRange  String?
  gstNumber    String?
  isVerified   Boolean  @default(false)
  targetNiches Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests  ContactRequest[] @relation("BrandProfileRequests")
  campaigns Campaign[]
  favorites Favorite[]

  @@map("brand_profiles")
}

model ContactRequest {
  id                String   @id @default(cuid())
  brandUserId       String
  influencerUserId  String
  brandProfileId    String
  influencerProfileId String
  tierType          String?
  message           String
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  brandUser         User              @relation("BrandRequests", fields: [brandUserId], references: [id])
  influencerUser    User              @relation("InfluencerRequests", fields: [influencerUserId], references: [id])
  influencerProfile InfluencerProfile @relation("InfluencerProfileRequests", fields: [influencerProfileId], references: [id])
  brandProfile      BrandProfile      @relation("BrandProfileRequests", fields: [brandProfileId], references: [id])
  messages          Message[]

  @@map("contact_requests")
}

model Campaign {
  id              String   @id @default(cuid())
  brandProfileId  String
  title           String
  description     String
  budget          Int
  targetNiches    Json     @default("[]")
  targetCities    Json?    @default("[]")
  minFollowers    Int?
  maxFollowers    Int?
  contentTypes    Json     @default("[]")
  status          String   @default("active")
  createdAt       DateTime @default(now())
  expiresAt       DateTime?
  updatedAt       DateTime @updatedAt

  brandProfile    BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  proposals       CampaignProposal[]

  @@map("campaigns")
}

model CampaignProposal {
  id                  String   @id @default(cuid())
  campaignId          String
  influencerProfileId String
  proposedPrice       Int
  message             String?
  deliverables        String?
  status              String   @default("pending")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  campaign            Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencerProfile   InfluencerProfile @relation(fields: [influencerProfileId], references: [id], onDelete: Cascade)

  @@map("campaign_proposals")
}

model Message {
  id          String   @id @default(cuid())
  requestId   String
  senderId    String
  receiverId  String
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  request     ContactRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender      User           @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User           @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([requestId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model Favorite {
  id                  String   @id @default(cuid())
  brandProfileId      String
  influencerProfileId String
  createdAt           DateTime @default(now())

  brandProfile        BrandProfile      @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  influencerProfile   InfluencerProfile @relation(fields: [influencerProfileId], references: [id], onDelete: Cascade)

  @@unique([brandProfileId, influencerProfileId])
  @@map("favorites")
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String   // Hashed OTP
  purpose   String   // "signup" | "reset-password"
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
  @@map("otp_verifications")
}
